---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Artists', href: '/artists' },
  { label: 'Releases', href: '/releases' },
  { label: 'Events', href: '/events' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <nav class="mx-auto flex max-w-[1440px] items-center justify-between px-8 py-6 md:px-10 md:py-7">
    <!-- Logo -->
    <a href="/" class="relative" style="z-index: 102;">
      <img
        src="/images/logos/wordmark-chartreuse.svg"
        alt="Handmade Records"
        class="h-5 md:h-7 header-logo transition-opacity duration-300"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden items-center gap-10 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-mono text-[13px] uppercase tracking-[0.12em] transition-colors duration-200',
              (link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href))
                ? 'text-chartreuse'
                : 'text-white/70 hover:text-chartreuse',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="relative flex h-12 w-12 items-center justify-center md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      type="button"
      style="z-index: 102; -webkit-tap-highlight-color: transparent; touch-action: manipulation;"
    >
      <div class="pointer-events-none" id="burger-icon">
        <span id="bar1" class="block h-[2px] w-6 bg-chartreuse transition-all duration-300 origin-center" style="margin-bottom: 6px;"></span>
        <span id="bar2" class="block h-[2px] w-6 bg-chartreuse transition-all duration-300 origin-center"></span>
      </div>
    </button>
  </nav>
</header>

<!-- Mobile Menu — separate from header, uses fixed positioning with highest z-index -->
<div
  id="mobile-menu"
  style="
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    display: none;
    background: rgba(0, 0, 0, 0.98);
    -webkit-backdrop-filter: blur(40px);
    backdrop-filter: blur(40px);
  "
>
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; width: 100%;">
    <ul style="display: flex; flex-direction: column; align-items: center; gap: 28px; list-style: none; padding: 0; margin: 0;">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link font-sans text-3xl font-bold text-chartreuse"
            style="-webkit-tap-highlight-color: transparent; text-decoration: none; display: block; padding: 8px 24px;"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="mailto:friends@handmaderecords.co"
      class="font-mono text-white/30"
      style="margin-top: 48px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.15em; text-decoration: none;"
    >
      friends@handmaderecords.co
    </a>
  </div>
</div>

<script>
  function setupMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const header = document.getElementById('site-header');
    if (!toggle || !menu || !bar1 || !bar2 || !header) return;

    let isOpen = false;

    function open() {
      isOpen = true;
      menu.style.display = 'block';
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.top = `-${window.scrollY}px`;
      bar1.style.transform = 'rotate(45deg) translate(2px, 2px)';
      bar2.style.transform = 'rotate(-45deg) translate(2px, -2px)';
      toggle.setAttribute('aria-expanded', 'true');
    }

    function close() {
      const scrollY = document.body.style.top;
      isOpen = false;
      menu.style.display = 'none';
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
      document.body.style.top = '';
      window.scrollTo(0, parseInt(scrollY || '0') * -1);
      bar1.style.transform = '';
      bar2.style.transform = '';
      toggle.setAttribute('aria-expanded', 'false');
    }

    // Toggle handler
    function doToggle() {
      if (isOpen) close();
      else open();
    }

    // Touch + click handling for iOS
    let didTouch = false;
    toggle.addEventListener('touchstart', function(e) {
      e.preventDefault();
      didTouch = true;
      doToggle();
    }, { passive: false });

    toggle.addEventListener('click', function(e) {
      e.preventDefault();
      if (didTouch) { didTouch = false; return; }
      doToggle();
    });

    // Close when tapping a nav link
    menu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        close();
      });
    });

    // Scroll behavior for header background
    let wasScrolled = false;
    function checkScroll() {
      const scrolled = window.scrollY > 40;
      if (scrolled !== wasScrolled) {
        wasScrolled = scrolled;
        if (scrolled) {
          header.style.background = 'rgba(0,0,0,0.9)';
          header.style.backdropFilter = 'blur(12px)';
          header.style.webkitBackdropFilter = 'blur(12px)';
          header.style.boxShadow = '0 1px 0 rgba(255,255,255,0.05)';
        } else {
          header.style.background = '';
          header.style.backdropFilter = '';
          header.style.webkitBackdropFilter = '';
          header.style.boxShadow = '';
        }
      }
    }
    window.addEventListener('scroll', checkScroll, { passive: true });
    checkScroll();
  }

  // Ensure clean setup on every page load / view transition
  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
  document.addEventListener('astro:page-load', setupMenu);
</script>
