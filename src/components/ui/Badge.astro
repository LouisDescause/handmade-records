---
interface Props {
  variant?: 'default' | 'chartreuse' | 'outline';
}

const { variant = 'default' } = Astro.props;

const variants = {
  default: 'bg-black/5 text-black/70',
  chartreuse: 'bg-chartreuse text-black',
  outline: 'border border-white/20 text-white/70',
};
---

<span class:list={['inline-block px-2.5 py-0.5 font-mono text-[12px] uppercase tracking-[0.12em]', variants[variant]]}>
  <slot />
</span>
