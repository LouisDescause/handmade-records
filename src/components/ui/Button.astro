---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'sm' | 'md';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className } = Astro.props;
const Tag = href ? 'a' : 'button';

const base = 'inline-flex items-center justify-center font-mono text-xs uppercase tracking-[0.12em] transition-all duration-200';
const sizes = { sm: 'px-4 py-2', md: 'px-6 py-3' };
const variants = {
  primary: 'bg-chartreuse text-black hover:bg-white',
  outline: 'border border-chartreuse text-chartreuse hover:bg-chartreuse hover:text-black',
  ghost: 'text-chartreuse hover:text-white',
};
---

<Tag href={href} class:list={[base, sizes[size], variants[variant], className]}>
  <slot />
</Tag>
