---
interface Props {
  id?: string;
  count?: number;
  class?: string;
}

const { id = 'particles', count = 45, class: className = '' } = Astro.props;
---

<canvas
  data-particles
  data-count={count}
  id={id}
  class:list={['absolute inset-0 w-full h-full pointer-events-none', className]}
  style="z-index: 1;"
></canvas>

<script>
  function initAllParticles() {
    document.querySelectorAll('canvas[data-particles]').forEach((el) => {
      const canvas = el as HTMLCanvasElement;
      if (canvas.dataset.initialized === 'true') return;
      canvas.dataset.initialized = 'true';

      const section = canvas.parentElement as HTMLElement;
      if (!section) return;

      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const count = parseInt(canvas.dataset.count || '45', 10);
      let mouseX = -1000;
      let mouseY = -1000;
      let animId: number;

      type Particle = {
        x: number; y: number; vx: number; vy: number;
        size: number; alpha: number; baseAlpha: number;
        color: string; drift: number; pulse: number;
      };

      let particles: Particle[] = [];

      const colors = [
        'rgba(255, 180, 80,',
        'rgba(255, 200, 100,',
        'rgba(231, 252, 186,',
        'rgba(255, 160, 60,',
        'rgba(255, 220, 150,',
      ];

      function resize() {
        const rect = section.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
      }

      function createParticles() {
        particles = [];
        const c = Math.min(count, Math.floor((canvas.width * canvas.height) / 18000));
        for (let i = 0; i < c; i++) {
          particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.25,
            vy: (Math.random() - 0.5) * 0.25 - 0.1,
            size: Math.random() * 2.2 + 0.5,
            alpha: 0,
            baseAlpha: Math.random() * 0.4 + 0.1,
            color: colors[Math.floor(Math.random() * colors.length)],
            drift: Math.random() * Math.PI * 2,
            pulse: Math.random() * 0.02 + 0.005,
          });
        }
      }

      section.addEventListener('mousemove', (e) => {
        const rect = section.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
      });
      section.addEventListener('mouseleave', () => {
        mouseX = -1000;
        mouseY = -1000;
      });

      function animate() {
        if (!ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (const p of particles) {
          p.drift += p.pulse;
          p.x += p.vx + Math.sin(p.drift) * 0.15;
          p.y += p.vy + Math.cos(p.drift * 0.7) * 0.08;

          const dx = p.x - mouseX;
          const dy = p.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const mouseRadius = 140;

          if (dist < mouseRadius) {
            const force = (1 - dist / mouseRadius) * 0.7;
            p.x += (dx / dist) * force;
            p.y += (dy / dist) * force;
            p.alpha = Math.min(1, p.baseAlpha + force * 1.2);
          } else {
            p.alpha += (p.baseAlpha - p.alpha) * 0.02;
          }

          if (p.x < -10) p.x = canvas.width + 10;
          if (p.x > canvas.width + 10) p.x = -10;
          if (p.y < -10) p.y = canvas.height + 10;
          if (p.y > canvas.height + 10) p.y = -10;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = p.color + p.alpha + ')';
          ctx.fill();

          if (p.size > 1.2) {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
            ctx.fillStyle = p.color + (p.alpha * 0.08) + ')';
            ctx.fill();
          }
        }

        animId = requestAnimationFrame(animate);
      }

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            resize();
            if (particles.length === 0) createParticles();
            animate();
          } else {
            cancelAnimationFrame(animId);
          }
        });
      }, { threshold: 0.05 });
      obs.observe(section);

      window.addEventListener('resize', () => {
        resize();
        createParticles();
      });
    });
  }

  initAllParticles();
  document.addEventListener('astro:after-swap', () => {
    // Reset initialized flags after page swap
    document.querySelectorAll('canvas[data-particles]').forEach((el) => {
      (el as HTMLCanvasElement).dataset.initialized = '';
    });
    initAllParticles();
  });
</script>
