---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Contact" description="Get in touch with Handmade Records. Submit demos, business inquiries, and more.">

  <!-- Hero -->
  <section class="relative bg-black pt-28 pb-12 md:pt-36 md:pb-16 overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-0 opacity-[0.03]"></div>
    <div class="mx-auto max-w-[1280px] px-6 relative z-10">
      <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/50 reveal">Say Hello</p>
      <h1 class="mt-3 font-sans text-[clamp(2.5rem,7vw,5rem)] font-bold leading-[0.85] tracking-tight text-white reveal">
        Get in Touch
      </h1>
      <p class="mt-5 max-w-[500px] text-base leading-relaxed text-white/50 reveal">
        Whether you're an artist, collaborator, press, or just a fan — we'd love to hear from you.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-chartreuse/20 to-transparent"></div>
  </section>

  <!-- General Contact -->
  <section class="bg-black py-20 md:py-28">
    <div class="mx-auto max-w-[1280px] px-6">
      <div class="grid gap-16 lg:grid-cols-[1fr_1.2fr]">

        <!-- Info Side -->
        <div class="reveal">
          <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40">General Inquiries</p>
          <p class="mt-5 text-base leading-relaxed text-white/55">
            For press, partnerships, bookings, or just to say hello — drop us a line and we'll get back to you.
          </p>

          <div class="mt-10 space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-white/[0.04]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-chartreuse/60"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white/30">Email</p>
                <a href="mailto:friends@handmaderecords.co" class="text-base text-white hover:text-chartreuse transition-colors">friends@handmaderecords.co</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-white/[0.04]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-chartreuse/60"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white/30">Location</p>
                <p class="text-base text-white/70">Los Angeles, CA</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-white/[0.04]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-chartreuse/60"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              </div>
              <div>
                <p class="font-mono text-[12px] uppercase tracking-[0.12em] text-white/30">Social</p>
                <a href="https://instagram.com/handmaderecords" target="_blank" rel="noopener" class="text-base text-white hover:text-chartreuse transition-colors">@handmaderecords</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Form Side -->
        <div class="reveal">
          <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-6 rounded-xl border border-white/[0.06] bg-white/[0.02] p-8 md:p-10">
            <div>
              <label for="name" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Name</label>
              <input type="text" id="name" name="name" required class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse placeholder:text-white/20" />
            </div>
            <div>
              <label for="email" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Email</label>
              <input type="email" id="email" name="email" required class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse placeholder:text-white/20" />
            </div>
            <div>
              <label for="subject" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Subject</label>
              <select id="subject" name="subject" required class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse [&>option]:bg-neutral-900 [&>option]:text-white">
                <option value="">Select...</option>
                <option value="general">General Inquiry</option>
                <option value="press">Press</option>
                <option value="partnership">Business / Partnership</option>
                <option value="booking">Booking</option>
              </select>
            </div>
            <div>
              <label for="social-handle" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Instagram / TikTok Handle</label>
              <input type="text" id="social-handle" name="social_handle" placeholder="@yourhandle" class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse placeholder:text-white/15" />
            </div>
            <div>
              <label for="message" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse resize-none placeholder:text-white/20"></textarea>
            </div>
            <div class="hidden" aria-hidden="true">
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>
            <button type="submit" class="inline-flex items-center gap-3 rounded-full bg-chartreuse px-7 py-3.5 font-mono text-[13px] uppercase tracking-[0.15em] text-black transition-all duration-300 hover:shadow-[0_0_25px_rgba(231,252,186,0.2)] hover:gap-5">
              Send Message <span class="text-base">&#8594;</span>
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Demo Submissions -->
  <section class="relative bg-neutral-950 py-20 md:py-28 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent"></div>
    <div class="mx-auto max-w-[800px] px-6">
      <div class="reveal text-center">
        <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40">For Artists</p>
        <h2 class="mt-2 font-sans text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-white">Submit Your Demo</h2>
        <p class="mt-4 text-base leading-relaxed text-white/50">
          We're always looking for one-of-a-kind artists. If you think your sound belongs on Handmade, send us your music. We listen to everything.
        </p>
      </div>

      <form action="https://formspree.io/f/your-demo-form-id" method="POST" class="mt-12 space-y-6 reveal">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="artist-name" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Artist / Band Name</label>
            <input type="text" id="artist-name" name="artist_name" required class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse" />
          </div>
          <div>
            <label for="demo-email" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Email</label>
            <input type="email" id="demo-email" name="email" required class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse" />
          </div>
        </div>
        <div>
          <label for="genre" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Genre / Style</label>
          <input type="text" id="genre" name="genre" class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse" />
        </div>
        <div>
          <label for="music-link" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Link to Music (SoundCloud, Bandcamp, Google Drive, etc.)</label>
          <input type="url" id="music-link" name="music_link" required placeholder="https://" class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white placeholder:text-white/15 outline-none transition-colors focus:border-chartreuse" />
        </div>
        <div>
          <label for="socials" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Social Links</label>
          <input type="text" id="socials" name="social_links" placeholder="@handle or URLs" class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white placeholder:text-white/15 outline-none transition-colors focus:border-chartreuse" />
        </div>
        <div>
          <label for="demo-message" class="block font-mono text-[12px] uppercase tracking-[0.12em] text-white/40 mb-2">Tell us about yourself</label>
          <textarea id="demo-message" name="message" rows="4" class="w-full border-b border-white/10 bg-transparent py-3 text-base text-white outline-none transition-colors focus:border-chartreuse resize-none"></textarea>
        </div>
        <div class="hidden" aria-hidden="true">
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        </div>
        <div class="text-center pt-2">
          <button type="submit" class="inline-flex items-center gap-3 rounded-full bg-chartreuse px-7 py-3.5 font-mono text-[13px] uppercase tracking-[0.15em] text-black transition-all duration-300 hover:shadow-[0_0_25px_rgba(231,252,186,0.2)] hover:gap-5">
            Submit Demo <span class="text-base">&#8594;</span>
          </button>
        </div>
      </form>
    </div>
  </section>

</PageLayout>

<style>
  .grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    mix-blend-mode: overlay;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Form input focus glow */
  input:focus, select:focus, textarea:focus {
    border-color: #E7FCBA !important;
    box-shadow: 0 1px 0 0 rgba(231, 252, 186, 0.3);
  }

  /* Button press effect on mobile */
  button[type="submit"]:active {
    transform: scale(0.97);
  }
</style>

<script>
  function initContact() {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach((el) => observer.observe(el));
  }

  initContact();
  document.addEventListener('astro:after-swap', initContact);
</script>
