---
import PageLayout from '../../layouts/PageLayout.astro';

const showcases = [
  { num: 16, image: '/images/events/showcase-16.jpg', artists: 'Debbii Dawson, Amelie Kalia, Ellie Irwin', date: 'Mar 2026' },
  { num: 15, image: '/images/events/showcase-15.jpg', artists: 'Dev Lemons, Sunfingers, Aliana White', date: 'Feb 2026' },
  { num: 14, image: '/images/events/showcase-14.jpg', artists: 'Chrissy, Phoenix Wonder, Anya True', date: 'Jan 2026' },
  { num: 13, image: '/images/events/showcase-13.jpg', artists: 'Grace Enger, Ella Jane, EJ Ross', date: 'Oct 2025' },
  { num: 12, image: '/images/events/showcase-12.jpg', artists: 'Dacelynn, Gus, Lauren Juzang', date: 'Sep 2025' },
  { num: 11, image: '/images/events/showcase-11.jpg', artists: 'Lucy Clearwater, GGwendolyn, Marie Dresselhuis', date: 'Aug 2025' },
  { num: 10, image: '/images/events/showcase-10.jpg', artists: 'G Lune, Superflirt, True Jackson', date: 'Jul 2025' },
  { num: 9, image: '/images/events/showcase-9.jpg', artists: 'TheBandFriday, Tristan', date: 'Jun 2025' },
  { num: 8, image: '/images/events/showcase-8.jpg', artists: 'Annika Bennett, Harrison Borts', date: 'May 2025' },
  { num: 7, image: '/images/events/showcase-7.jpg', artists: 'Ella Atkinson, Stav McAllister, Nia Ashleigh', date: 'Feb 2025' },
  { num: 6, image: '/images/events/showcase-6.jpg', artists: 'Sabrina Sterling, Conall Cafferty, Ruby Plume', date: 'Jan 2025' },
  { num: 5, image: '/images/events/showcase-5.jpg', artists: 'Zoe Sparks, Valley Boy, Abby Holliday', date: 'Oct 2024' },
  { num: 4, image: '/images/events/showcase-4.jpg', artists: 'Georgia Parker, Claire Brooks, Fin Peach', date: 'Sep 2024' },
  { num: 3, image: '/images/events/showcase-3.jpg', artists: 'Dior Goodjohn, Beeson, Anna Beck', date: 'Aug 2024' },
  { num: 2, image: '/images/events/showcase-2.jpg', artists: 'Holden McRae, Eli Torg, Ellie Williams', date: 'Feb 2024' },
  { num: 1, image: '/images/events/showcase-1.jpg', artists: 'Margot Liotta, Aimee Vant, Jacob Wright', date: 'Jan 2024' },
];
---

<PageLayout title="Events" description="Handmade Live Showcases — LA's backyard concert series for discovering new artists, networking, and community.">

  <!-- Hero -->
  <section class="relative bg-black pt-28 pb-12 md:pt-36 md:pb-16 overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-0 opacity-[0.03]"></div>
    <div class="mx-auto max-w-[1280px] px-6 relative z-10">
      <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/50 reveal">Live Events</p>
      <h1 class="mt-3 font-sans text-[clamp(2.5rem,7vw,5.5rem)] font-bold leading-[0.85] tracking-tight text-white reveal">
        Handmade Live
      </h1>
      <p class="mt-6 max-w-[640px] text-base leading-relaxed text-white/55 reveal">
        Handmade Live is our backyard concert series — an intimate night of live music, community, and discovery in Los Angeles. Past showcases have featured performances from Annika Bennett, Grace Enger, Tristan, Amelie Kalia, Fin Peach, TheBandFriday, Harrison Borts, Dev Lemons, Ella Jane, and many more. With live tattoos, free drinks, and a room full of creatives — it's the place to discover your next favorite artist and be part of something real.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 reveal">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 px-4 py-1.5 font-mono text-[12px] uppercase tracking-[0.1em] text-white/40">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          LA, California
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 px-4 py-1.5 font-mono text-[12px] uppercase tracking-[0.1em] text-white/40">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          16 Showcases & Counting
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 px-4 py-1.5 font-mono text-[12px] uppercase tracking-[0.1em] text-white/40">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          Live Music + Tattoos + Drinks
        </span>
      </div>
    </div>
  </section>

  <!-- 3D Showcase Crate -->
  <section class="relative bg-black overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-10 opacity-[0.035]"></div>

    <div class="mx-auto max-w-[1280px] px-6 md:px-10 pt-8 pb-2">
      <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40 reveal">Archive</p>
      <h2 class="mt-2 font-sans text-[clamp(1.5rem,3vw,2rem)] font-bold tracking-tight text-white reveal">Past Showcases</h2>
    </div>

    <div
      id="crate"
      class="crate-scroll relative flex items-end gap-0 overflow-x-auto py-10 md:py-14"
      style="perspective: 900px; -webkit-overflow-scrolling: touch;"
    >
      <!-- Left spacer -->
      <div class="flex-shrink-0" style="width: max(1.5rem, calc((100vw - 1280px) / 2 + 2.5rem));"></div>

      {showcases.map((show, i) => (
        <div
          class="crate-card group relative flex-shrink-0 cursor-default"
          data-artists={show.artists}
          data-date={show.date}
          data-vol={show.num}
          style={`width: clamp(200px, 25vw, 320px); aspect-ratio: 1; margin-left: ${i === 0 ? '0' : 'clamp(-50px, -6vw, -30px)'}; z-index: ${showcases.length - i};`}
        >
          <img
            src={show.image}
            alt={`Handmade Live Vol. ${show.num}`}
            class="pointer-events-none block h-full w-full rounded object-cover"
            draggable="false"
            loading="lazy"
          />
          <!-- Hover overlay with artists -->
          <div class="card-overlay pointer-events-none absolute inset-0 flex flex-col items-center justify-center rounded bg-black/75 p-5 text-center opacity-0 transition-opacity duration-300 backdrop-blur-sm">
            <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-chartreuse">Vol. {show.num} — {show.date}</p>
            <div class="mt-3 space-y-0.5">
              {show.artists.split(', ').map((artist) => (
                <p class="font-sans text-[14px] font-semibold text-white leading-snug">{artist}</p>
              ))}
            </div>
          </div>
        </div>
      ))}

      <!-- Right spacer -->
      <div class="flex-shrink-0 w-[20vw]"></div>
    </div>

    <!-- Hover info — bottom left -->
    <div id="hover-info" class="absolute bottom-4 left-6 z-20 transition-opacity duration-300 opacity-0 md:bottom-6 md:left-10">
      <p id="info-vol" class="font-mono text-[12px] uppercase tracking-[0.2em] text-chartreuse/60"></p>
      <p id="info-artists" class="mt-0.5 font-sans text-base font-bold text-white md:text-lg"></p>
      <p id="info-date" class="mt-0.5 font-mono text-[13px] text-white/50"></p>
    </div>

    <!-- Count -->
    <div class="absolute bottom-4 right-6 z-20 md:bottom-6 md:right-10">
      <p class="font-mono text-[12px] text-white/20">{showcases.length} showcases</p>
    </div>
  </section>

  <!-- Highlight Reel -->
  <section class="bg-black py-16 md:py-24">
    <div class="mx-auto max-w-[1280px] px-6 md:px-10">
      <div class="reveal mb-8">
        <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40">Watch</p>
        <h2 class="mt-1 font-sans text-[clamp(1.5rem,3vw,2.25rem)] font-semibold tracking-tight text-white">
          Highlight Reel
        </h2>
      </div>
      <div class="reveal rounded-xl overflow-hidden" style="aspect-ratio: 16/9;">
        <iframe
          src="https://www.youtube.com/embed/HGrf4BCnU2g?rel=0&modestbranding=1&color=white"
          title="Handmade Live Highlight Reel"
          width="100%"
          height="100%"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          style="border: 0;"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-chartreuse py-16 md:py-24 overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-0 opacity-[0.06]"></div>
    <div class="mx-auto max-w-[800px] px-6 text-center relative z-10">
      <p class="font-sans text-[clamp(1.15rem,2.5vw,1.5rem)] font-medium leading-relaxed text-black reveal">
        Want to perform at the next Handmade Live? We're always looking for incredible new artists to feature.
      </p>
      <div class="mt-8 reveal">
        <a href="/contact" class="inline-flex items-center gap-3 rounded-full bg-black px-8 py-4 font-mono text-[13px] uppercase tracking-[0.15em] text-chartreuse transition-all duration-300 hover:gap-5 hover:shadow-[0_0_30px_rgba(0,0,0,0.3)]">
          Get in Touch <span class="text-base">&#8594;</span>
        </a>
      </div>
      <p class="mt-6 font-mono text-[12px] uppercase tracking-[0.15em] text-black/30 reveal">
        Follow <a href="https://instagram.com/handmaderecords" target="_blank" rel="noopener" class="text-black/50 underline transition-colors hover:text-black">@handmaderecords</a> for announcements
      </p>
    </div>
  </section>

</PageLayout>

<style>
  .grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    mix-blend-mode: overlay;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .crate-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .crate-scroll::-webkit-scrollbar {
    display: none;
  }

  .crate-card {
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
                filter 0.4s ease;
    transform: rotateY(-12deg) translateZ(0px);
    filter: brightness(0.65) saturate(0.9);
    overflow: hidden;
    border-radius: 6px;
    box-shadow: -6px 4px 25px rgba(0,0,0,0.6);
    transform-style: preserve-3d;
  }

  .crate-card:hover {
    transform: rotateY(-3deg) translateZ(60px) scale(1.08);
    filter: brightness(1.1) saturate(1.1) !important;
    z-index: 200 !important;
    box-shadow: -4px 8px 40px rgba(0,0,0,0.8);
  }

  .crate-card:hover .card-overlay {
    opacity: 1;
  }

  /* Touch-friendly: active state on mobile */
  @media (hover: none) {
    .crate-card {
      transform: rotateY(-6deg) translateZ(0px);
      filter: brightness(0.75) saturate(0.95);
    }
  }
</style>

<script>
  function initEvents() {
    // Reveals
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach((el) => observer.observe(el));

    // Crate scroll
    const crate = document.getElementById('crate') as HTMLElement;
    const cards = document.querySelectorAll('.crate-card') as NodeListOf<HTMLElement>;
    const hoverInfo = document.getElementById('hover-info') as HTMLElement;
    const infoVol = document.getElementById('info-vol');
    const infoArtists = document.getElementById('info-artists');
    const infoDate = document.getElementById('info-date');

    if (!crate || cards.length === 0) return;

    // Drag to scroll
    let isDragging = false;
    let startX = 0;
    let startScroll = 0;
    let dragDelta = 0;
    let velocity = 0;
    let lastX = 0;
    let lastTime = 0;
    let momentumId: number;

    crate.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.pageX;
      startScroll = crate.scrollLeft;
      dragDelta = 0;
      velocity = 0;
      lastX = e.pageX;
      lastTime = Date.now();
      crate.style.cursor = 'grabbing';
      cancelAnimationFrame(momentumId);
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const dx = startX - e.pageX;
      dragDelta = Math.abs(dx);
      crate.scrollLeft = startScroll + dx;

      const now = Date.now();
      const dt = now - lastTime;
      if (dt > 0) {
        velocity = (lastX - e.pageX) / dt;
        lastX = e.pageX;
        lastTime = now;
      }
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      crate.style.cursor = '';

      let v = velocity * 200;
      function momentum() {
        if (Math.abs(v) < 0.5) return;
        crate.scrollLeft += v * 0.016;
        v *= 0.95;
        momentumId = requestAnimationFrame(momentum);
      }
      momentum();
    });

    // Hover: dim others, show info
    cards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        if (isDragging) return;
        cards.forEach((other) => {
          if (other !== card) {
            other.style.filter = 'brightness(0.2) saturate(0.5)';
          }
        });
        if (hoverInfo && infoVol && infoArtists && infoDate) {
          infoVol.textContent = `Vol. ${card.dataset.vol}`;
          infoArtists.textContent = card.dataset.artists || '';
          infoDate.textContent = card.dataset.date || '';
          hoverInfo.style.opacity = '1';
        }
      });

      card.addEventListener('mouseleave', () => {
        cards.forEach((other) => {
          other.style.filter = '';
        });
        if (hoverInfo) {
          hoverInfo.style.opacity = '0';
        }
      });
    });
  }

  initEvents();
  document.addEventListener('astro:after-swap', initEvents);
</script>
