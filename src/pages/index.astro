---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allArtists = await getCollection('artists');
const featuredArtists = allArtists
  .filter((a) => a.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title="Home">

  <!-- HERO -->
  <section class="flex min-h-screen items-center justify-center bg-black">
    <div class="flex flex-col items-center px-6 text-center">
      <img
        src="/images/logos/lockup-chartreuse.svg"
        alt="Handmade Records"
        class="w-[300px] md:w-[500px] lg:w-[680px] xl:w-[780px]"
        transition:name="hero-logo"
      />
      <!-- Scroll indicator -->
      <div class="mt-12 animate-bounce">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/30 mx-auto"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </div>
    </div>
  </section>

  <!-- ABOUT — who we are -->
  <section class="relative bg-black py-24 md:py-32 lg:py-40 overflow-hidden">
    <!-- Dimmed background photo -->
    <img
      src="/images/about/handmade-live-bg.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover opacity-[0.08]"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-chartreuse/15 to-transparent"></div>

    <div class="relative mx-auto max-w-[1080px] px-6">
      <!-- Centered intro -->
      <div class="reveal mx-auto max-w-[640px] text-center">
        <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40">About Us</p>
        <h2 class="mt-4 font-sans text-[clamp(1.75rem,3.5vw,2.75rem)] font-semibold leading-[1.1] tracking-tight text-white">
          An independent record label<br class="hidden sm:inline" /> built for artists.
        </h2>
        <p class="mt-6 text-base leading-relaxed text-white/50">
          Founded in 2024 in Los Angeles with a simple belief: the best music comes from artists who are given the freedom to be themselves. We work across Pop, Folk, Alternative, Indie, Rap, Hip Hop, R&B — and wherever the music takes us.
        </p>
      </div>

      <!-- Value cards -->
      <div class="mt-20 grid gap-5 md:grid-cols-3">
        <div class="reveal value-card group rounded-2xl border border-white/[0.06] bg-white/[0.02] p-8 transition-all duration-500 backdrop-blur-sm" style="transition-delay: 0s">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-chartreuse text-[13px] font-semibold text-black transition-transform duration-500 group-hover:scale-110 group-hover:rotate-[-4deg]">01</span>
          <h3 class="mt-5 font-sans text-lg font-semibold text-white group-hover:text-chartreuse transition-colors duration-300">Artist-First</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
            Every decision starts with what's best for the artist. Creative control stays where it belongs.
          </p>
        </div>
        <div class="reveal value-card group rounded-2xl border border-white/[0.06] bg-white/[0.02] p-8 transition-all duration-500 backdrop-blur-sm" style="transition-delay: 0.1s">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-chartreuse text-[13px] font-semibold text-black transition-transform duration-500 group-hover:scale-110 group-hover:rotate-[-4deg]">02</span>
          <h3 class="mt-5 font-sans text-lg font-semibold text-white group-hover:text-chartreuse transition-colors duration-300">Creative Freedom</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
            We don't chase trends. We invest in artists with a distinct vision and give them space to realize it.
          </p>
        </div>
        <div class="reveal value-card group rounded-2xl border border-white/[0.06] bg-white/[0.02] p-8 transition-all duration-500 backdrop-blur-sm" style="transition-delay: 0.2s">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-chartreuse text-[13px] font-semibold text-black transition-transform duration-500 group-hover:scale-110 group-hover:rotate-[-4deg]">03</span>
          <h3 class="mt-5 font-sans text-lg font-semibold text-white group-hover:text-chartreuse transition-colors duration-300">Community</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
            Live showcases and collaborative projects that build genuine connections between artists and audiences.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ROSTER — 3D fan cards -->
  <section class="bg-black py-20 md:py-28 overflow-hidden">
    <div class="mx-auto max-w-[1080px] px-6">
      <div class="reveal flex items-end justify-between">
        <div>
          <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/50">The Roster</p>
          <h2 class="mt-2 font-sans text-[clamp(1.75rem,3.5vw,2.75rem)] font-semibold tracking-tight text-white">Our Artists</h2>
        </div>
        <a href="/artists" class="link-slide hidden items-center gap-2 font-mono text-[13px] uppercase tracking-[0.12em] text-white/40 transition-colors hover:text-chartreuse sm:inline-flex">
          View All <span class="text-base">&#8594;</span>
        </a>
      </div>

      <!-- 3D perspective fan — desktop -->
      <div id="artist-fan" class="relative mt-16 hidden md:flex items-center justify-center" style="perspective: 1200px; height: 420px;">
        {featuredArtists.map((artist, i) => {
          const total = featuredArtists.length;
          const offset = i - Math.floor(total / 2);
          const rotate = offset * 8;
          const translateX = offset * 220;
          const translateZ = -Math.abs(offset) * 40;
          return (
            <a
              href={`/artists/${artist.id}`}
              class="artist-card group absolute transition-all duration-500 ease-out"
              style={`transform: translateX(${translateX}px) translateZ(${translateZ}px) rotateY(${rotate}deg); z-index: ${total - Math.abs(offset)};`}
              data-rotate={rotate}
              data-tx={translateX}
              data-tz={translateZ}
              data-z={total - Math.abs(offset)}
            >
              <div class="relative h-[360px] w-[260px] overflow-hidden rounded-lg shadow-2xl shadow-black/50 transition-all duration-500 ease-out">
                <img
                  src={artist.data.photo}
                  alt={artist.data.name}
                  class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                  transition:name={`artist-img-${artist.id}`}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition-opacity duration-300"></div>
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  <p class="font-mono text-[13px] uppercase tracking-[0.15em] text-chartreuse/70 opacity-0 translate-y-2 transition-all duration-400 ease-out group-hover:opacity-100 group-hover:translate-y-0">
                    {artist.data.genres[0]}
                  </p>
                  <h3 class="mt-1 font-sans text-xl font-semibold text-white transition-colors duration-300 group-hover:text-chartreuse">
                    {artist.data.name}
                  </h3>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Mobile horizontal scroll cards -->
      <div class="mt-10 -mx-6 px-6 flex gap-4 overflow-x-auto scrollbar-hide snap-x snap-mandatory pb-4 md:hidden" style="-webkit-overflow-scrolling: touch;">
        {featuredArtists.map((artist) => (
          <a href={`/artists/${artist.id}`} class="group flex-shrink-0 snap-start" style="width: 70vw; max-width: 280px;">
            <div class="relative aspect-[3/4] overflow-hidden rounded-lg shadow-xl shadow-black/50">
              <img
                src={artist.data.photo}
                alt={artist.data.name}
                class="h-full w-full object-cover transition-transform duration-500 active:scale-105"
                transition:name={`artist-img-${artist.id}`}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-5">
                <p class="font-mono text-[12px] uppercase tracking-[0.15em] text-chartreuse/70">
                  {artist.data.genres[0]}
                </p>
                <h3 class="mt-1 font-sans text-xl font-semibold text-white">
                  {artist.data.name}
                </h3>
              </div>
            </div>
          </a>
        ))}
      </div>

      <a href="/artists" class="mt-8 inline-flex items-center gap-2 font-mono text-[13px] uppercase tracking-[0.12em] text-white/40 transition-colors hover:text-chartreuse sm:hidden">
        View All <span class="text-base">&#8594;</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-chartreuse py-20 md:py-28">
    <div class="reveal mx-auto max-w-[800px] px-6 text-center">
      <p class="font-sans text-[clamp(1.25rem,2.5vw,1.75rem)] font-medium leading-relaxed text-black">
        Interested in working with us? Whether you're an artist, collaborator, or just a fan — we'd love to hear from you.
      </p>
      <div class="mt-10">
        <a href="/contact" class="link-slide inline-flex items-center gap-2 font-mono text-[13px] uppercase tracking-[0.12em] text-black/50 transition-colors hover:text-black">
          Get in Touch <span class="text-base">&#8594;</span>
        </a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .value-card {
    cursor: default;
  }
  .value-card:hover {
    border-color: rgba(231, 252, 186, 0.15);
    background: rgba(231, 252, 186, 0.04);
    transform: translateY(-6px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3),
                0 0 0 1px rgba(231, 252, 186, 0.08);
  }
  @media (max-width: 767px) {
    .value-card:active {
      border-color: rgba(231, 252, 186, 0.15);
      background: rgba(231, 252, 186, 0.04);
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initHomepage() {
    // ---- Scroll reveal with stagger ----
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach((el) => observer.observe(el));

    // ---- Artist fan hover (desktop) ----
    const cards = document.querySelectorAll('.artist-card') as NodeListOf<HTMLElement>;
    const fan = document.getElementById('artist-fan');
    if (fan && cards.length > 0) {
      cards.forEach((card) => {
        card.addEventListener('mouseenter', () => {
          cards.forEach((c) => {
            if (c === card) {
              c.style.transform = `translateX(${c.dataset.tx}px) translateZ(80px) rotateY(0deg) scale(1.08)`;
              c.style.zIndex = '20';
              c.style.filter = 'brightness(1)';
            } else {
              c.style.transform = `translateX(${c.dataset.tx}px) translateZ(${Number(c.dataset.tz) - 30}px) rotateY(${c.dataset.rotate}deg) scale(0.95)`;
              c.style.zIndex = c.dataset.z || '1';
              c.style.filter = 'brightness(0.5)';
            }
          });
        });
      });
      fan.addEventListener('mouseleave', () => {
        cards.forEach((c) => {
          c.style.transform = `translateX(${c.dataset.tx}px) translateZ(${c.dataset.tz}px) rotateY(${c.dataset.rotate}deg) scale(1)`;
          c.style.zIndex = c.dataset.z || '1';
          c.style.filter = 'brightness(1)';
        });
      });
    }

    // ---- Parallax scroll for hero ----
    const hero = document.querySelector('section:first-child') as HTMLElement;
    if (hero) {
      const heroContent = hero.querySelector('.relative.flex.flex-col') as HTMLElement;
      if (heroContent) {
        window.addEventListener('scroll', () => {
          const scrollY = window.scrollY;
          const heroH = hero.offsetHeight;
          if (scrollY < heroH) {
            const progress = scrollY / heroH;
            heroContent.style.transform = `translateY(${scrollY * 0.3}px)`;
            heroContent.style.opacity = `${1 - progress * 1.2}`;
          }
        }, { passive: true });
      }
    }
  }

  // Run on load + after view transitions
  initHomepage();
  document.addEventListener('astro:after-swap', initHomepage);
</script>
