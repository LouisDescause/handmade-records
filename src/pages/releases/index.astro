---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allReleases = await getCollection('releases');
const releases = allReleases.sort((a, b) => new Date(b.data.release_date).getTime() - new Date(a.data.release_date).getTime());
---

<PageLayout title="Releases" description="Explore the Handmade Records discography.">

  <!-- Header -->
  <section class="bg-black pt-32 pb-6 md:pt-40 md:pb-8">
    <div class="mx-auto max-w-[1280px] px-6 md:px-10">
      <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40">Discography</p>
      <h1 class="mt-1 font-sans text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[0.9] tracking-tight text-white">
        Releases
      </h1>
    </div>
  </section>

  <!-- Crate -->
  <section class="relative bg-black overflow-hidden">
    <!-- Grain -->
    <div class="grain pointer-events-none absolute inset-0 z-10 opacity-[0.035]"></div>

    <div
      id="crate"
      class="crate-scroll relative flex items-end gap-0 overflow-x-auto py-12 md:py-16"
      style="perspective: 900px; -webkit-overflow-scrolling: touch;"
    >
      <!-- Left spacer -->
      <div class="flex-shrink-0" style="width: max(1.5rem, calc((100vw - 1280px) / 2 + 2.5rem));"></div>

      {releases.map((release, i) => (
        <a
          href={`/releases/${release.id}`}
          class="crate-card group relative flex-shrink-0"
          data-i={i}
          data-artist={release.data.artist}
          data-title={release.data.title}
          data-type={release.data.type}
          style={`width: clamp(220px, 30vw, 380px); aspect-ratio: 1; margin-left: ${i === 0 ? '0' : 'clamp(-80px, -10vw, -50px)'}; z-index: ${releases.length - i};`}
        >
          <img
            src={release.data.cover}
            alt={release.data.title}
            class="pointer-events-none block h-full w-full rounded object-cover"
            draggable="false"
          />
          <!-- Hover label -->
          <div class="card-label pointer-events-none absolute inset-0 flex items-center justify-center rounded opacity-0 transition-opacity duration-300">
            <span class="rounded-full bg-black/80 px-5 py-2.5 font-mono text-[13px] uppercase tracking-[0.15em] text-white backdrop-blur-sm md:text-[12px]">
              {release.data.title}
            </span>
          </div>
        </a>
      ))}

      <!-- Right spacer -->
      <div class="flex-shrink-0 w-[20vw]"></div>
    </div>

    <!-- Hover info — bottom left of crate -->
    <div id="hover-info" class="absolute bottom-4 left-6 z-20 transition-opacity duration-300 opacity-0 md:bottom-6 md:left-10">
      <p id="info-type" class="font-mono text-[12px] uppercase tracking-[0.2em] text-chartreuse/60"></p>
      <p id="info-title" class="mt-0.5 font-sans text-lg font-bold text-white md:text-xl"></p>
      <p id="info-artist" class="mt-0.5 font-mono text-[13px] text-white/50"></p>
    </div>

    <!-- Release count -->
    <div class="absolute bottom-4 right-6 z-20 md:bottom-6 md:right-10">
      <p class="font-mono text-[12px] text-white/20">{releases.length} releases</p>
    </div>
  </section>

</PageLayout>

<style>
  .grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    mix-blend-mode: overlay;
  }

  .crate-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .crate-scroll::-webkit-scrollbar {
    display: none;
  }

  .crate-card {
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
                filter 0.4s ease;
    transform: rotateY(-12deg) translateZ(0px);
    filter: brightness(0.6) saturate(0.9);
    overflow: hidden;
    border-radius: 4px;
    box-shadow: -6px 4px 25px rgba(0,0,0,0.6);
    transform-style: preserve-3d;
  }

  .crate-card:hover {
    transform: rotateY(-3deg) translateZ(60px) scale(1.06);
    filter: brightness(1.1) saturate(1.1) !important;
    z-index: 200 !important;
    box-shadow: -4px 8px 40px rgba(0,0,0,0.8);
  }

  .crate-card:hover .card-label {
    opacity: 1;
  }

  /* Touch-friendly: lighter default on mobile */
  @media (hover: none) {
    .crate-card {
      transform: rotateY(-6deg) translateZ(0px);
      filter: brightness(0.75) saturate(0.95);
    }
  }
</style>

<script>
  function initReleases() {
    const crate = document.getElementById('crate') as HTMLElement;
    const cards = document.querySelectorAll('.crate-card') as NodeListOf<HTMLElement>;
    const hoverInfo = document.getElementById('hover-info') as HTMLElement;
    const infoTitle = document.getElementById('info-title');
    const infoArtist = document.getElementById('info-artist');
    const infoType = document.getElementById('info-type');

    if (!crate || cards.length === 0) return;

    // Drag to scroll (desktop)
    let isDragging = false;
    let startX = 0;
    let startScroll = 0;
    let dragDelta = 0;
    let velocity = 0;
    let lastX = 0;
    let lastTime = 0;
    let momentumId: number;

    crate.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.pageX;
      startScroll = crate.scrollLeft;
      dragDelta = 0;
      velocity = 0;
      lastX = e.pageX;
      lastTime = Date.now();
      crate.style.cursor = 'grabbing';
      cancelAnimationFrame(momentumId);
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const dx = startX - e.pageX;
      dragDelta = Math.abs(dx);
      crate.scrollLeft = startScroll + dx;

      const now = Date.now();
      const dt = now - lastTime;
      if (dt > 0) {
        velocity = (lastX - e.pageX) / dt;
        lastX = e.pageX;
        lastTime = now;
      }
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      crate.style.cursor = '';

      // Momentum scroll
      let v = velocity * 200;
      function momentum() {
        if (Math.abs(v) < 0.5) return;
        crate.scrollLeft += v * 0.016;
        v *= 0.95;
        momentumId = requestAnimationFrame(momentum);
      }
      momentum();
    });

    // Prevent click-through while dragging
    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        if (dragDelta > 8) e.preventDefault();
      });
    });

    // Hover: dim others, show info
    cards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        if (isDragging) return;

        cards.forEach((other) => {
          if (other !== card) {
            other.style.filter = 'brightness(0.2) saturate(0.5)';
          }
        });

        if (hoverInfo && infoTitle && infoArtist && infoType) {
          infoTitle.textContent = card.dataset.title || '';
          infoArtist.textContent = card.dataset.artist || '';
          infoType.textContent = card.dataset.type || '';
          hoverInfo.style.opacity = '1';
        }
      });

      card.addEventListener('mouseleave', () => {
        cards.forEach((other) => {
          other.style.filter = '';
        });

        if (hoverInfo) {
          hoverInfo.style.opacity = '0';
        }
      });
    });
  }

  initReleases();
  document.addEventListener('astro:after-swap', initReleases);
</script>
