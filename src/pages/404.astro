---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Not Found">
  <section class="flex min-h-screen items-center justify-center bg-black">
    <div class="px-6 text-center">
      <p class="font-mono text-[12px] uppercase tracking-[0.15em] text-chartreuse/50">404</p>
      <h1 class="mt-3 font-sans text-[clamp(2rem,5vw,4rem)] font-bold tracking-tight text-white">
        Page Not Found
      </h1>
      <p class="mt-4 text-base text-white/40">The page you're looking for doesn't exist.</p>
      <div class="mt-8">
        <a href="/" class="inline-flex items-center gap-2 font-mono text-[13px] uppercase tracking-[0.12em] text-chartreuse/60 transition-colors hover:text-chartreuse">
          <span>&#8592;</span> Back Home
        </a>
      </div>
    </div>
  </section>
</PageLayout>
