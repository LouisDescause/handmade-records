---
import PageLayout from '../layouts/PageLayout.astro';
import Particles from '../components/Particles.astro';
---

<PageLayout title="About" description="The story behind Handmade Records — an LA-based independent label fostering greatness.">

  <!-- Hero -->
  <section class="relative bg-black pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-10 opacity-[0.03]"></div>
    <Particles id="about-hero-particles" count={35} />
    <div class="mx-auto max-w-[1280px] px-6 relative z-20">
      <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/50 reveal">Est. 2024 — Los Angeles</p>
      <h1 class="mt-4 font-sans text-[clamp(3rem,8vw,7rem)] font-bold leading-[0.85] tracking-tight text-white reveal">
        Fostering<br />Greatness
      </h1>
      <p class="mt-6 max-w-[520px] text-lg leading-relaxed text-white/50 reveal">
        An independent label built on one belief — the best music comes from artists who are free to be themselves.
      </p>
    </div>
    <!-- Animated line -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-chartreuse/30 to-transparent"></div>
  </section>

  <!-- Chapter 1: The Beginning -->
  <section class="relative bg-black py-24 md:py-32 overflow-hidden">
    <div class="mx-auto max-w-[1280px] px-6">
      <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div>
          <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40 reveal">Chapter 01</p>
          <h2 class="mt-3 font-sans text-[clamp(2rem,4vw,3.5rem)] font-bold leading-[0.9] tracking-tight text-white reveal">
            How It<br />Started
          </h2>
          <div class="mt-8 space-y-5 reveal">
            <p class="text-base leading-relaxed text-white/60">
              Handmade Records was started by Jonathan "Jono" Wachter when he identified a gap in the record business — true artist development was extremely rare to come by and communities of creatives simply did not exist.
            </p>
            <p class="text-base leading-relaxed text-white/60">
              His goal: fix this and build an independent label that understood the game — social media content, branding, digital marketing, and above all, <span class="text-white font-medium">music first</span>.
            </p>
          </div>
        </div>
        <div class="relative reveal">
          <div class="relative overflow-hidden rounded-lg">
            <img
              src="/images/about/handmade-live-2.jpg"
              alt="Handmade Live Showcase — artist performing on stage"
              class="parallax-img w-full h-auto object-cover transition-transform duration-100 will-change-transform"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <p class="absolute bottom-4 left-4 font-mono text-[12px] uppercase tracking-[0.15em] text-white/50">Handmade Live</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapter 2: The Mission -->
  <section class="relative bg-black py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent"></div>
    <div class="mx-auto max-w-[1280px] px-6 relative z-10">
      <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div class="md:order-2">
          <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40 reveal">Chapter 02</p>
          <h2 class="mt-3 font-sans text-[clamp(2rem,4vw,3.5rem)] font-bold leading-[0.9] tracking-tight text-white reveal">
            What We<br />Believe
          </h2>
          <div class="mt-8 space-y-5 reveal">
            <p class="text-base leading-relaxed text-white/60">
              One of the pillars of Handmade Records is our artist development — the ability to help artists refine their sound and take records across the finish line thanks to our top-tier services and hands-on team.
            </p>
            <p class="text-base leading-relaxed text-white/60">
              We're not here to acquire a bunch of catalog for the lowest price. We're here to help artists incubate and build <span class="text-white font-medium">long-term careers</span>.
            </p>
          </div>
        </div>
        <div class="relative md:order-1 reveal">
          <div class="relative overflow-hidden rounded-lg">
            <img
              src="/images/about/handmade-live-3.jpg"
              alt="Handmade Live Showcase — intimate performance setting"
              class="parallax-img w-full h-auto object-cover max-h-[500px] transition-transform duration-100 will-change-transform"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <p class="absolute bottom-4 right-4 font-mono text-[12px] uppercase tracking-[0.15em] text-white/50">Handmade Live</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider quote -->
  <section class="relative bg-black py-16 md:py-24 overflow-hidden">
    <div class="mx-auto max-w-[900px] px-6 text-center">
      <blockquote class="reveal">
        <p class="font-sans text-[clamp(1.5rem,3.5vw,2.5rem)] font-bold leading-[1.15] tracking-tight text-white">
          "We're not just here to sell records.<br class="hidden md:block" />
          <span class="text-chartreuse">We're here to create an ecosystem where independent artists can genuinely thrive.</span>"
        </p>
      </blockquote>
    </div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </section>

  <!-- What We Do — Service Cards -->
  <section class="relative bg-black py-24 md:py-32 overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-0 opacity-[0.03]"></div>
    <div class="mx-auto max-w-[1280px] px-6 relative z-10">
      <p class="font-mono text-[12px] uppercase tracking-[0.25em] text-chartreuse/40 reveal">Chapter 03</p>
      <h2 class="mt-3 font-sans text-[clamp(2rem,4vw,3.5rem)] font-bold leading-[0.9] tracking-tight text-white reveal">
        What We Do
      </h2>

      <div class="mt-14 grid gap-5 md:grid-cols-2">

        <!-- A&R / Scouting -->
        <div class="service-card group reveal">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />
            </svg>
          </div>
          <div>
            <h3 class="font-sans text-lg font-bold text-white group-hover:text-chartreuse transition-colors duration-300">A&R / Scouting</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
              We discover and develop one-of-a-kind talent, building long-term partnerships rooted in trust. Not just looking for what's hot — looking for what's real.
            </p>
          </div>
        </div>

        <!-- Release Strategy -->
        <div class="service-card group reveal">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20V10" /><path d="M18 20V4" /><path d="M6 20v-4" />
            </svg>
          </div>
          <div>
            <h3 class="font-sans text-lg font-bold text-white group-hover:text-chartreuse transition-colors duration-300">Release Strategy</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
              From singles to full albums, we craft rollout plans that serve the music and reach the right ears at the right time. Every release has a story.
            </p>
          </div>
        </div>

        <!-- Live Events -->
        <div class="service-card group reveal">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" />
            </svg>
          </div>
          <div>
            <h3 class="font-sans text-lg font-bold text-white group-hover:text-chartreuse transition-colors duration-300">Live Events</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
              Our Handmade Live Showcases bring artists and audiences together for unforgettable nights. Real rooms, real energy, real connection.
            </p>
          </div>
        </div>

        <!-- Creative Direction -->
        <div class="service-card group reveal">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z" />
            </svg>
          </div>
          <div>
            <h3 class="font-sans text-lg font-bold text-white group-hover:text-chartreuse transition-colors duration-300">Creative Direction</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/50 group-hover:text-white/70 transition-colors duration-300">
              Visual identity, branding, and storytelling that amplifies each artist's unique voice. We don't do templates — every project is handmade.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-chartreuse py-20 md:py-28 overflow-hidden">
    <div class="grain pointer-events-none absolute inset-0 z-0 opacity-[0.06]"></div>
    <div class="mx-auto max-w-[800px] px-6 text-center relative z-10">
      <p class="font-sans text-[clamp(1.25rem,2.5vw,1.75rem)] font-medium leading-relaxed text-black reveal">
        Interested in working with us? Whether you're an artist, collaborator, or just a fan — we'd love to hear from you.
      </p>
      <div class="mt-10 reveal">
        <a href="/contact" class="inline-flex items-center gap-3 rounded-full bg-black px-8 py-4 font-mono text-[13px] uppercase tracking-[0.15em] text-chartreuse transition-all duration-300 hover:gap-5 hover:shadow-[0_0_30px_rgba(0,0,0,0.3)]">
          Get in Touch <span class="text-base">&#8594;</span>
        </a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    mix-blend-mode: overlay;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Service cards */
  .service-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .service-card:hover {
    border-color: rgba(231, 252, 186, 0.15);
    background: rgba(231, 252, 186, 0.04);
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3),
                0 0 0 1px rgba(231, 252, 186, 0.08);
  }

  .service-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.4);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .service-card:hover .service-icon,
  .service-card.touch-active .service-icon {
    background: rgba(231, 252, 186, 0.12);
    color: #E7FCBA;
    transform: scale(1.1) rotate(-4deg);
  }

  .service-card.touch-active {
    border-color: rgba(231, 252, 186, 0.15);
    background: rgba(231, 252, 186, 0.04);
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3),
                0 0 0 1px rgba(231, 252, 186, 0.08);
  }

  /* Big chapter numbers */
  .story-number {
    transition: opacity 0.6s ease;
  }
</style>

<script>
  function initAbout() {
    // Scroll reveal with stagger
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const siblings = el.parentElement?.querySelectorAll('.reveal');
          let sibIndex = 0;
          if (siblings) {
            siblings.forEach((s, i) => { if (s === el) sibIndex = i; });
          }
          setTimeout(() => {
            el.classList.add('is-visible');
          }, sibIndex * 120);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
    reveals.forEach((el) => observer.observe(el));

    // Parallax on images
    const parallaxImages = document.querySelectorAll('.parallax-img') as NodeListOf<HTMLElement>;
    if (parallaxImages.length > 0 && window.innerWidth >= 768) {
      window.addEventListener('scroll', () => {
        parallaxImages.forEach((img) => {
          const rect = img.getBoundingClientRect();
          const viewH = window.innerHeight;
          if (rect.top < viewH && rect.bottom > 0) {
            const progress = (viewH - rect.top) / (viewH + rect.height);
            const shift = (progress - 0.5) * 40;
            img.style.transform = `translateY(${shift}px) scale(1.05)`;
          }
        });
      }, { passive: true });
    }

    // Touch-friendly service cards
    const serviceCards = document.querySelectorAll('.service-card') as NodeListOf<HTMLElement>;
    serviceCards.forEach((card) => {
      card.addEventListener('touchstart', () => {
        serviceCards.forEach(c => c.classList.remove('touch-active'));
        card.classList.add('touch-active');
      }, { passive: true });
    });
  }

  initAbout();
  document.addEventListener('astro:after-swap', initAbout);
</script>
